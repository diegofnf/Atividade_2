POSTGRES_IMAGE=postgres:18.3
POSTGRES_CONTAINER_NAME=topicos-av2-postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_dev
POSTGRES_TEST_DB=app_test
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_dev

# Judge provider selection.
JUDGE_PROVIDER=remote_http

# Remote HTTP judge endpoint.
# Use your own Colab, Hugging Face Inference Endpoint, vLLM, llama.cpp,
# LM Studio, Ollama proxy, or other OpenAI-compatible endpoint.
REMOTE_JUDGE_BASE_URL=https://your-remote-endpoint.example.com/v1
REMOTE_JUDGE_API_KEY=replace-me

# Default execution mode.
# Supported values: single, primary_only, 2plus1
JUDGE_PANEL_MODE=2plus1

# Default single judge fallback.
# Used only in single mode when --judge-model is omitted.
REMOTE_JUDGE_MODEL=m-prometheus-14b

# 2 + 1 judge architecture.
REMOTE_PRIMARY_JUDGE_PANEL=gpt-oss-120b,llama-3.3-70b-instruct
REMOTE_ARBITER_JUDGE_MODEL=m-prometheus-14b

# Arbitration rule.
JUDGE_ARBITRATION_MIN_DELTA=2
JUDGE_ALWAYS_RUN_ARBITER=false

# Judge API call scheduling.
# sequential is safer for local models with limited VRAM.
# parallel can reduce wall time with remote endpoints that support concurrency.
# Supported values: sequential, parallel
JUDGE_EXECUTION_STRATEGY=sequential

# Remote generation parameters.
REMOTE_JUDGE_TIMEOUT_SECONDS=180
REMOTE_JUDGE_TEMPERATURE=0.0
REMOTE_JUDGE_MAX_TOKENS=1200
REMOTE_JUDGE_TOP_P=1.0

# OpenAI-compatible mode.
REMOTE_JUDGE_OPENAI_COMPATIBLE=true

# Optional debug/audit. Never store secrets here.
JUDGE_SAVE_RAW_RESPONSE=true
